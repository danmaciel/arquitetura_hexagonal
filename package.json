  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "migration:make": "knex migrate:make --knexfile ./src/exemplo/adapters/db/knex/knexfile.ts",
